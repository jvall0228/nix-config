#!/usr/bin/env bash
set -euo pipefail

GREEN='\033[1;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

HOST="${1:-thinkpad}"
if [[ ! "$HOST" =~ ^[a-zA-Z0-9_-]+$ ]]; then
  echo "Error: Invalid hostname '$HOST'" >&2
  exit 1
fi

echo -e "${YELLOW}Building and switching to: ${HOST}${NC}"
sudo nixos-rebuild switch --flake .#"$HOST"
echo -e "${GREEN}Switch complete!${NC}"
